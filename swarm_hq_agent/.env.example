## Model auth (choose one approach)
#
# Option A: Gemini API key (AI Studio)
# GOOGLE_API_KEY="..."
#
# Option B: Vertex AI
# GOOGLE_GENAI_USE_VERTEXAI=1
# GOOGLE_CLOUD_PROJECT="your-gcp-project"
# GOOGLE_CLOUD_LOCATION="us-central1"

## GitHub MCP auth (required)
# Use a token that can read org repos/projects and write issues/projects as desired.
GITHUB_PERSONAL_ACCESS_TOKEN="..."

## SwarmHQ configuration (optional)
# GitHub org to scope all access to (defaults to "swarmhq-demo")
SWARMHQ_ORG_OWNER="swarmhq-demo"

# Optional override for the local MCP server binary path.
# If omitted, SwarmHQ auto-detects common locations:
# - ./swarm_hq_agent/bin/github-mcp-server (recommended)
# - ./bin/github-mcp-server
# GITHUB_MCP_COMMAND="./swarm_hq_agent/bin/github-mcp-server"

